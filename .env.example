# ════════════════════════════════════════════════════════════════════════════
#  SolarAdvisor — Environment Variables
#  Copy to .env.local for local dev. On Railway, set in the Variables tab.
# ════════════════════════════════════════════════════════════════════════════

# ─── DATABASE ────────────────────────────────────────────────────────────────
#
# RAILWAY (automatic — just add these as Variable References from the MySQL plugin):
#   MYSQL_URL               → reference MYSQL_URL from MySQL plugin
#   MYSQL_ROOT_PASSWORD     → reference MYSQL_ROOT_PASSWORD from MySQL plugin
#   MYSQLHOST               → reference MYSQLHOST from MySQL plugin
#
# The app reads: MYSQL_URL first, then falls back to individual vars.
# Tables are created automatically on every deploy — no manual migration needed.
#
# LOCAL DEVELOPMENT — set these in .env.local:
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-local-root-password
MYSQL_DATABASE=solaradvisor

# ─── APP URLs ────────────────────────────────────────────────────────────────
# Set these to your actual Railway domain after first deploy
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app
NEXTAUTH_URL=https://your-app.up.railway.app

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32-output

# ─── ADMIN ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@solaradvisor.com
# Generate with: node -e "require('bcryptjs').hash('YourPass123!', 12).then(console.log)"
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash

# ─── GOOGLE MAPS (satellite imagery + Solar API) ─────────────────────────────
# Enable: Maps Static API + Solar API at console.cloud.google.com
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSyAqryliUhCBj-M-BmZT8IlDbsZoN7I_w8M

# ─── GOOGLE VERTEX AI (photo-realistic image generation) ─────────────────────
# Optional — AiImage component uses CSS fallback when not set
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Run: gcloud auth print-access-token  (rotates hourly — use service account in prod)
GOOGLE_CLOUD_ACCESS_TOKEN=

# ─── HUGGING FACE (image generation fallback) ────────────────────────────────
# Optional — free tier at huggingface.co/settings/tokens
HUGGING_FACE_TOKEN=

# ─── ANTHROPIC (live chat AI) ────────────────────────────────────────────────
# Optional — chat uses rule-based fallback when not set
ANTHROPIC_API_KEY=

# ─── EMAIL (lead notifications) ──────────────────────────────────────────────
# Optional — notifications logged to console when not set
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=SolarAdvisor <noreply@solaradvisor.com>

# ─── TWILIO (SMS notifications) ──────────────────────────────────────────────
# Optional — SMS skipped when not set
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── LEAD PRICING (cents) ────────────────────────────────────────────────────
LEAD_PRICE_HOT=15000
LEAD_PRICE_MEDIUM=7500
LEAD_PRICE_LOW=2500

# ─── PARTNER WEBHOOK ─────────────────────────────────────────────────────────
# Optional — hot leads pushed to this URL with HMAC-SHA256 signature
PARTNER_WEBHOOK_URL=
PARTNER_WEBHOOK_SECRET=
