# ─── Database ────────────────────────────────────────────────────────────────
#
# RAILWAY DEPLOYMENT (automatic):
#   1. In Railway dashboard → your web service → Variables tab
#   2. Click "Add Variable Reference" and select MYSQL_URL from the MySQL plugin
#   3. That is ALL you need — Railway injects MYSQL_URL automatically
#   4. Tables are created on first deploy via scripts/apply-migrate.mjs (auto-runs)
#
# Railway MySQL plugin injects these automatically (you do NOT need to set them manually):
#   MYSQL_URL              mysql://root:password@host:port/railway
#   MYSQLPRIVATE_URL       same URL via private network (faster, use this)
#   MYSQL_HOST / MYSQLHOST
#   MYSQL_PORT / MYSQLPORT
#   MYSQL_USER / MYSQLUSER
#   MYSQL_PASSWORD / MYSQLPASSWORD
#   MYSQL_DATABASE / MYSQLDATABASE  (default value is "railway")
#
# LOCAL DEVELOPMENT ONLY — set these in .env.local (never commit):
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=solaradvisor
MYSQL_USER=root
MYSQL_PASSWORD=your-local-password
# Optional: set to 1 to skip migrate.sql on container start (not recommended in prod)
# SKIP_DB_MIGRATE=0

# ─── App ────────────────────────────────────────────────────────────────────
# Optional: production start script forces HOSTNAME=0.0.0.0 (Railway overwrites HOSTNAME)
NEXT_PUBLIC_APP_URL=https://your-app.railway.app
NEXTAUTH_URL=https://your-app.railway.app
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ─── Twilio (SMS) ────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Email (Nodemailer / SMTP) ───────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
EMAIL_FROM=SolarAdvisor <noreply@solaradvisor.com>

# ─── Admin ──────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@solaradvisor.com
ADMIN_PASSWORD_HASH=bcrypt-hash-here

# ─── Google Maps (optional satellite imagery) ────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key

# ─── Lead Pricing (cents) ────────────────────────────────────────────────────
LEAD_PRICE_HOT=15000
LEAD_PRICE_MEDIUM=7500
LEAD_PRICE_LOW=2500

# ─── Webhook (notify installers / partners) ──────────────────────────────────
PARTNER_WEBHOOK_URL=https://your-crm.com/webhook/leads
PARTNER_WEBHOOK_SECRET=your-webhook-secret

# ─── AI Image Generation (Google Vertex AI Imagen) ───────────────────────────
# Get from: https://console.cloud.google.com → APIs → Vertex AI
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Run: gcloud auth print-access-token  (refresh hourly in prod use service account)
GOOGLE_CLOUD_ACCESS_TOKEN=ya29.your-access-token

# ─── AI Image Fallback (Hugging Face SDXL) ───────────────────────────────────
# Free tier available: https://huggingface.co/settings/tokens
HUGGING_FACE_TOKEN=hf_your_token_here

# ─── Live Chat AI (Anthropic Claude Haiku) ───────────────────────────────────
# Optional — chat works rule-based without this key
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here
